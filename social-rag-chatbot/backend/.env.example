# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# LLM Configuration
LLM_MODEL_PATH=./models/llama-2-7b-chat.Q4_K_M.gguf
LLM_CONTEXT_LENGTH=4096
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Alternative: Use Ollama API
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Use Ollama instead of local GGUF
USE_OLLAMA=true

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=video_comparison_collection

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Whisper
WHISPER_MODEL=base

# Frontend
FRONTEND_URL=http://localhost:5173